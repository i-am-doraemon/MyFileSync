<Window x:Class="MyFileSync.src.FileListingMonitor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyFileSync.src"
        mc:Ignorable="d"
        Title="ファイル一覧の作成中..." SizeToContent="WidthAndHeight" ResizeMode="NoResize">
    <StackPanel Orientation="Vertical">
        <Label Name="doReport" Content="現在0個あるファイル中、0個目までのファイル（0%）を完了。。。" Margin="20,30,20,30" HorizontalAlignment="Center"/>
        <Button Content="キャンセル" Click="OnDoCancel" Width="60" Margin="0,0,20,20" HorizontalAlignment="Right" />
    </StackPanel>
</Window>
