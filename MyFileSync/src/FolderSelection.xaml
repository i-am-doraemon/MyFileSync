<Window x:Class="MyFileSync.FolderSelection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyFileSync"
        mc:Ignorable="d"
        Title="フォルダ選択" SizeToContent="WidthAndHeight">
    <StackPanel Orientation="Vertical">
        <Label Content="比較するフォルダを選択してください。" Margin="20, 20, 20, 10"/>
        <StackPanel Orientation="Horizontal">
            <Label Content="左: " Margin="20,10,10,20"/>
            <TextBox Name="doInputFolder1" Margin="0,10,20,20" Width="360" FontSize="18"/>
            <Button Content="フォルダを選択" Click="OnDoChooseFolder1" Margin="0,10,20,20"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="右: " Margin="20,10,10,20"/>
            <TextBox Name="doInputFolder2" Margin="0,10,20,20" Width="360" FontSize="18"/>
            <Button Content="フォルダを選択" Click="OnDoChooseFolder2" Margin="0,10,20,20" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="OnDoOK" Width="60" Margin="20,20,10,20"/>
            <Button Content="キャンセル" Width="60" Margin="10,20,20,20"/>
        </StackPanel>
    </StackPanel>
</Window>
