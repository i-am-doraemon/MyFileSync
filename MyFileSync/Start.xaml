<Window x:Class="MyFileSync.Start"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyFileSync"
        mc:Ignorable="d"
        Title="MyFileSync" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル">
                <MenuItem Header="比較するフォルダを選択する" Click="OnDoSelectFolders"/>
            </MenuItem>
        </Menu>
        <DataGrid Name="doListUpFiles" IsReadOnly="True"/>
    </DockPanel>
</Window>
